# Copie para .env e preencha após o primeiro deploy da infra (CDK outputs).
SITE_URL=https://example.com
PUBLIC_API_BASE_URL=https://example.com/api
BLOG_TABLE_NAME=

# Manter "false" até resolver os bloqueadores em
# ADSENSE_READINESS_AND_RECOMMENDATIONS.md. Com "false" (ou ausente), nenhum
# código/host do Google entra no HTML e o banner de cookies não é renderizado.
PUBLIC_ADSENSE_ENABLED=false
