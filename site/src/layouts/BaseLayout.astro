---
import CookieConsent from "../components/CookieConsent.astro";
import { canonicalUrl } from "../lib/seo";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  path: string;
  image?: string;
  type?: "website" | "article";
  jsonLd?: Record<string, unknown>;
}

const { title, description, path, image, type = "website", jsonLd } = Astro.props;
const canonical = canonicalUrl(Astro.site ?? "https://example.com", path);
const ogImage = canonicalUrl(Astro.site ?? "https://example.com", image ?? "/logo-social.png");
const usesDefaultOgImage = !image;
// Escape "<" so a post title/description containing "</script>" can't break
// out of this JSON-LD block and inject a live <script> tag (title/description
// are free text from DynamoDB, not sanitized like the Markdown body).
const jsonLdScript = jsonLd ? JSON.stringify(jsonLd).replace(/</g, "\\u003c") : undefined;
const currentPath = path;
const isCurrent = (href: string) => href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=3" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=3" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=3" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    {usesDefaultOgImage && <meta property="og:image:width" content="1200" />}
    {usesDefaultOgImage && <meta property="og:image:height" content="630" />}
    <meta property="og:image:alt" content={usesDefaultOgImage ? "Gotas Cultas" : title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={usesDefaultOgImage ? "Gotas Cultas" : title} />

    {jsonLdScript && (
      <script type="application/ld+json" set:html={jsonLdScript} />
    )}
  </head>
  <body>
    <a class="skip-link" href="#conteudo">Pular para o conteúdo</a>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="brand" aria-label="Gotas Cultas — página inicial">
          <img src="/logo-inline-700-blue.svg" width="216" height="50" alt="" />
        </a>
        <nav class="desktop-nav" aria-label="Navegação principal">
          <a href="/" aria-current={isCurrent("/") ? "page" : undefined}>Início</a>
          <a href="/categoria/teologia/" aria-current={isCurrent("/categoria/teologia/") ? "page" : undefined}>Teologia</a>
          <a href="/categoria/filosofia/" aria-current={isCurrent("/categoria/filosofia/") ? "page" : undefined}>Filosofia</a>
          <a href="/sobre/" aria-current={isCurrent("/sobre/") ? "page" : undefined}>Sobre</a>
          <a href="/busca/" aria-current={isCurrent("/busca/") ? "page" : undefined}>Busca</a>
        </nav>
        <details class="mobile-nav">
          <summary>Menu</summary>
          <nav aria-label="Navegação principal móvel">
            <a href="/">Início</a><a href="/categoria/teologia/">Teologia</a><a href="/categoria/filosofia/">Filosofia</a><a href="/sobre/">Sobre</a><a href="/busca/">Busca</a>
          </nav>
        </details>
      </div>
    </header>

    <main id="conteudo" class="page-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div>
          <a class="footer-brand" href="/" aria-label="Gotas Cultas — página inicial">
            <img src="/logo-inline-700.svg" width="216" height="50" alt="Gotas Cultas" />
          </a>
          <p>Pequenas reflexões sobre as grandes questões.</p>
        </div>
        <p>&copy; {new Date().getFullYear()} Gotas Cultas · <a href="/privacidade/">Privacidade</a></p>
      </div>
    </footer>

    <CookieConsent />
  </body>
</html>

<style is:global>
  .site-header { border-bottom: 1px solid var(--color-line-300); background: var(--color-paper-100); }
  .header-inner { min-height: 80px; display: flex; align-items: center; justify-content: space-between; gap: var(--space-5); }
  .brand { display: block; width: 216px; flex: 0 0 216px; text-decoration: none; }
  .brand img { width: 100%; max-width: none; height: auto; }
  .footer-brand { color: var(--color-brand-900); font-family: var(--font-editorial); font-size: 1.45rem; font-weight: 600; text-decoration: none; }
  .desktop-nav { display: none; align-items: center; gap: var(--space-5); }
  .desktop-nav a { min-height: 44px; display: inline-flex; align-items: center; color: var(--color-ink-700); font-weight: 600; text-decoration: none; }
  .desktop-nav a:hover, .desktop-nav a[aria-current="page"] { color: var(--color-brand-700); text-decoration: underline; text-decoration-color: var(--color-gold-500); text-decoration-thickness: 2px; text-underline-offset: .45rem; }
  .mobile-nav { position: relative; }
  .mobile-nav summary { min-height: 44px; display: flex; align-items: center; cursor: pointer; font-weight: 700; }
  .mobile-nav nav { position: absolute; z-index: 20; top: calc(100% + .5rem); right: 0; min-width: 210px; padding: var(--space-3); border: 1px solid var(--color-line-300); background: var(--color-paper-50); box-shadow: 0 8px 24px rgb(11 43 51 / 12%); }
  .mobile-nav nav a { display: flex; min-height: 44px; align-items: center; padding-inline: var(--space-3); font-weight: 600; text-decoration: none; }
  .site-footer { padding-block: var(--space-8); background: var(--color-brand-900); color: var(--color-paper-200); }
  .site-footer a { color: var(--color-white); }
  .footer-inner { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: end; gap: var(--space-6); }
  .footer-inner p { margin: var(--space-2) 0 0; }
  .footer-brand { display: inline-block; }
  .footer-brand img { width: 216px; height: auto; }
  @media (max-width: 30rem) { .brand { width: 190px; flex-basis: 190px; } }
  @media (min-width: 48rem) { .desktop-nav { display: flex; } .mobile-nav { display: none; } }
</style>
