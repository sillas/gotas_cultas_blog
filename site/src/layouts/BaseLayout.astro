---
import CookieConsent from "../components/CookieConsent.astro";
import { canonicalUrl } from "../lib/seo";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  path: string;
  image?: string;
  type?: "website" | "article";
  jsonLd?: Record<string, unknown>;
}

const { title, description, path, image, type = "website", jsonLd } = Astro.props;
const canonical = canonicalUrl(Astro.site ?? "https://example.com", path);
const ogImage = canonicalUrl(Astro.site ?? "https://example.com", image ?? "/logo-social.png");
const usesDefaultOgImage = !image;
const contactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL || "contato@gotascultas.com.br";
const privacyEmail = import.meta.env.PUBLIC_PRIVACY_EMAIL || "privacidade@gotascultas.com.br";
// Escape "<" so a post title/description containing "</script>" can't break
// out of this JSON-LD block and inject a live <script> tag (title/description
// are free text from DynamoDB, not sanitized like the Markdown body).
const jsonLdScript = jsonLd ? JSON.stringify(jsonLd).replace(/</g, "\\u003c") : undefined;
const currentPath = path;
const isCurrent = (href: string) => href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f7f3e9" data-theme-color />
    <script is:inline>
      (() => {
        const storageKey = "gotas-cultas-theme";
        const media = window.matchMedia("(prefers-color-scheme: dark)");
        let preference = "system";

        try {
          const saved = localStorage.getItem(storageKey);
          if (saved === "light" || saved === "dark") preference = saved;
        } catch {}

        const applyTheme = (nextPreference) => {
          const theme = nextPreference === "system" ? (media.matches ? "dark" : "light") : nextPreference;
          document.documentElement.dataset.theme = theme;
          document.documentElement.dataset.themePreference = nextPreference;
          document.querySelector('[data-theme-color]')?.setAttribute("content", theme === "dark" ? "#10191c" : "#f7f3e9");
        };

        applyTheme(preference);

        document.addEventListener("DOMContentLoaded", () => {
          const button = document.querySelector("[data-theme-toggle]");
          const icon = button?.querySelector("[data-theme-icon]");
          const labels = { system: "automático", light: "claro", dark: "escuro" };
          const icons = { system: "◐", light: "☀", dark: "☾" };

          const updateButton = () => {
            const current = document.documentElement.dataset.themePreference || "system";
            if (icon) icon.textContent = icons[current];
            if (button) {
              button.setAttribute("aria-label", `Tema ${labels[current]}. Alterar tema`);
              button.setAttribute("title", `Tema: ${labels[current]}`);
            }
          };

          applyTheme(preference);

          button?.addEventListener("click", () => {
            const current = document.documentElement.dataset.themePreference || "system";
            const next = current === "system" ? "light" : current === "light" ? "dark" : "system";

            try {
              if (next === "system") localStorage.removeItem(storageKey);
              else localStorage.setItem(storageKey, next);
            } catch {}

            applyTheme(next);
            updateButton();
          });

          media.addEventListener("change", () => {
            if (document.documentElement.dataset.themePreference === "system") applyTheme("system");
          });

          updateButton();
        });
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=3" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=3" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=3" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    {usesDefaultOgImage && <meta property="og:image:width" content="1200" />}
    {usesDefaultOgImage && <meta property="og:image:height" content="630" />}
    <meta property="og:image:alt" content={usesDefaultOgImage ? "Gotas Cultas" : title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={usesDefaultOgImage ? "Gotas Cultas" : title} />

    {jsonLdScript && (
      <script type="application/ld+json" set:html={jsonLdScript} />
    )}
  </head>
  <body>
    <a class="skip-link" href="#conteudo">Pular para o conteúdo</a>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="brand" aria-label="Gotas Cultas — página inicial">
          <img src="/logo-inline-700.svg" width="216" height="50" alt="" data-brand-logo />
        </a>
        <div class="header-actions">
          <nav class="desktop-nav" aria-label="Navegação principal">
            <a href="/" aria-current={isCurrent("/") ? "page" : undefined}>Início</a>
            <a href="/categoria/teologia/" aria-current={isCurrent("/categoria/teologia/") ? "page" : undefined}>Teologia</a>
            <a href="/categoria/filosofia/" aria-current={isCurrent("/categoria/filosofia/") ? "page" : undefined}>Filosofia</a>
            <a href="/categoria/ciencia/" aria-current={isCurrent("/categoria/ciencia/") ? "page" : undefined}>Ciência</a>
            <a href="/sobre/" aria-current={isCurrent("/sobre/") ? "page" : undefined}>Sobre</a>
            <a href="/busca/" aria-current={isCurrent("/busca/") ? "page" : undefined}>Busca</a>
          </nav>
          <button class="theme-toggle" type="button" data-theme-toggle aria-label="Tema automático. Alterar tema" title="Tema: automático">
            <span aria-hidden="true" data-theme-icon>◐</span>
          </button>
          <details class="mobile-nav">
            <summary>Menu</summary>
            <nav aria-label="Navegação principal móvel">
              <a href="/" aria-current={isCurrent("/") ? "page" : undefined}>Início</a>
              <a href="/categoria/teologia/" aria-current={isCurrent("/categoria/teologia/") ? "page" : undefined}>Teologia</a>
              <a href="/categoria/filosofia/" aria-current={isCurrent("/categoria/filosofia/") ? "page" : undefined}>Filosofia</a>
              <a href="/categoria/ciencia/" aria-current={isCurrent("/categoria/ciencia/") ? "page" : undefined}>Ciência</a>
              <a href="/sobre/" aria-current={isCurrent("/sobre/") ? "page" : undefined}>Sobre</a>
              <a href="/busca/" aria-current={isCurrent("/busca/") ? "page" : undefined}>Busca</a>
            </nav>
          </details>
        </div>
      </div>
    </header>

    <main id="conteudo" class="page-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-intro">
          <a class="footer-brand" href="/" aria-label="Gotas Cultas — página inicial">
            <img src="/logo-inline-700.svg" width="216" height="50" alt="Gotas Cultas" />
          </a>
          <p>Pequenas reflexões sobre as grandes questões.</p>
        </div>
        <nav class="footer-explore" aria-labelledby="footer-explore-title">
          <h2 id="footer-explore-title">Explore</h2>
          <ul>
            <li><a href="/categoria/teologia/">Teologia</a></li>
            <li><a href="/busca/">Busca</a></li>
            <li><a href="/categoria/ciencia/">Ciência</a></li>
            <li><a href="/sobre/">Sobre</a></li>
            <li><a href="/categoria/filosofia/">Filosofia</a></li>
          </ul>
        </nav>
        <section class="footer-contact" aria-labelledby="footer-contact-title">
          <h2 id="footer-contact-title">Contato</h2>
          <p>Correções, sugestões e assuntos editoriais:<br /><a href={`mailto:${contactEmail}`}>{contactEmail}</a></p>
          <p>Privacidade e dados pessoais:<br /><a href={`mailto:${privacyEmail}`}>{privacyEmail}</a></p>
        </section>
        <p class="footer-legal">&copy; {new Date().getFullYear()} Gotas Cultas · <a href="/rss.xml" type="application/rss+xml">RSS</a> · <a href="/privacidade/" target="_blank" rel="noopener noreferrer">Privacidade</a></p>
      </div>
    </footer>

    <CookieConsent />
  </body>
</html>

<style is:global>
  .site-header {
    border-bottom: 2px solid var(--color-gold-500);
    background: linear-gradient(100deg, #0b2b33, #103640);
    color: var(--color-on-brand);
  }
  .header-inner { min-height: 80px; display: flex; align-items: center; justify-content: space-between; gap: var(--space-5); }
  .brand { display: block; width: 216px; flex: 0 0 216px; text-decoration: none; }
  .brand img { width: 100%; max-width: none; height: auto; }
  .footer-brand { color: var(--color-brand-900); font-family: var(--font-editorial); font-size: 1.45rem; font-weight: 600; text-decoration: none; }
  .header-actions { display: flex; align-items: center; gap: var(--space-3); }
  .desktop-nav { display: none; align-items: center; gap: var(--space-5); }
  .desktop-nav a { min-height: 44px; display: inline-flex; align-items: center; color: var(--color-on-brand); font-weight: 600; text-decoration: none; }
  .desktop-nav a:hover, .desktop-nav a[aria-current="page"] { color: var(--color-white); text-decoration: underline; text-decoration-color: var(--color-gold-500); text-decoration-thickness: 2px; text-underline-offset: .45rem; }
  .mobile-nav { position: relative; }
  .mobile-nav summary { min-height: 44px; display: flex; align-items: center; color: var(--color-on-brand); cursor: pointer; font-weight: 700; }
  .mobile-nav nav { position: absolute; z-index: 20; top: calc(100% + .5rem); right: 0; min-width: 210px; padding: var(--space-3); border: 1px solid var(--color-line-300); background: var(--color-paper-50); box-shadow: 0 8px 24px rgb(11 43 51 / 12%); }
  .mobile-nav nav a { display: flex; min-height: 44px; align-items: center; padding-inline: var(--space-3); font-weight: 600; text-decoration: none; }
  .theme-toggle { width: 44px; min-width: 44px; border: 1px solid var(--color-gold-500); border-radius: 50%; padding: 0; background: transparent; color: var(--color-on-brand); cursor: pointer; font-size: 1.15rem; line-height: 1; }
  .theme-toggle:hover { background: rgb(255 255 255 / 10%); color: var(--color-white); }
  .site-footer { padding-block: var(--space-8); background: var(--color-brand-900); color: var(--color-on-brand); }
  .site-footer a { color: var(--color-white); }
  .footer-inner { display: grid; gap: var(--space-6); }
  .footer-inner p { margin: var(--space-2) 0 0; }
  .footer-contact, .footer-explore { font-size: .9375rem; }
  .footer-contact h2, .footer-explore h2 { margin: 0 0 var(--space-3); color: var(--color-white); font-family: var(--font-interface); font-size: 1rem; font-weight: 700; }
  .footer-contact p { line-height: 1.45; }
  .footer-contact a { overflow-wrap: anywhere; }
  .footer-explore ul { display: grid; grid-template-columns: repeat(2, minmax(5rem, auto)); gap: var(--space-2) var(--space-5); margin: 0; padding: 0; list-style: none; }
  .footer-explore a { display: inline-flex; min-height: 30px; align-items: center; }
  .footer-legal { font-size: .9375rem; }
  .footer-brand { display: inline-block; }
  .footer-brand img { width: 216px; height: auto; }
  @media (max-width: 30rem) { .brand { width: 190px; flex-basis: 190px; } }
  @media (max-width: 22rem) { .header-inner { gap: var(--space-3); } .brand { width: 160px; flex-basis: 160px; } }
  @media (min-width: 48rem) { .footer-inner { grid-template-columns: repeat(2, minmax(0, 1fr)); align-items: start; } .footer-intro, .footer-legal { grid-column: 1 / -1; } .footer-legal { padding-top: var(--space-4); border-top: 1px solid rgb(255 255 255 / 18%); } }
  @media (min-width: 64rem) { .desktop-nav { display: flex; } .mobile-nav { display: none; } .footer-inner { grid-template-columns: minmax(15rem, 1fr) auto auto; } .footer-intro { grid-column: auto; } }
</style>
