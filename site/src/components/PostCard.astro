---
import type { Post } from "@blog/shared";
import ArticleMeta from "./ArticleMeta.astro";

interface Props {
  post: Post;
  variant?: "default" | "recent" | "featured";
}

const { post, variant = "default" } = Astro.props;
const readingMinutes = Math.max(1, Math.ceil(post.contentMarkdown.trim().split(/\s+/).length / 220));
const coverImage = post.coverImage?.status === "ready" ? post.coverImage : null;
const webpVariants = coverImage?.variants.filter((image) => image.format === "webp") ?? [];
const avifVariants = coverImage?.variants.filter((image) => image.format === "avif") ?? [];
const coverUrl = webpVariants.at(-1)?.url ?? coverImage?.fallbackUrl;
const imageSrcset = (variants: typeof webpVariants) => variants.map((image) => `${image.url} ${image.width}w`).join(", ");
---

<article class:list={["post-card", { "post-card--recent": variant === "recent", "post-card--featured": variant === "featured", "post-card--has-cover": variant === "featured" && Boolean(coverUrl) }]}>
  {variant === "featured" && coverUrl && (
    <a class="post-cover" href={`/post/${post.slug}/`} aria-label={`Ler ${post.title}`}>
      <picture>
        {avifVariants.length > 0 && <source type="image/avif" srcset={imageSrcset(avifVariants)} sizes="(max-width: 640px) 112px, 192px" />}
        {webpVariants.length > 0 && <source type="image/webp" srcset={imageSrcset(webpVariants)} sizes="(max-width: 640px) 112px, 192px" />}
        <img src={coverUrl} alt="" width="192" height="192" loading="eager" fetchpriority="high" />
      </picture>
    </a>
  )}
  <div class="post-card__content">
    <ArticleMeta category={post.category} publishAt={post.publishAt} readingMinutes={readingMinutes} />
    <h2><a href={`/post/${post.slug}/`}>{post.title}</a></h2>
    <p class="post-excerpt">{post.description}</p>
  </div>
</article>

<style>
  .post-card {
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--color-line-300);
  }
  .post-card--recent {
    padding: var(--space-5) 0 var(--space-5) var(--space-4);
    border-bottom: 0;
    border-left: 5px solid var(--color-gold-500);
  }
  .post-card--featured.post-card--has-cover {
    display: grid;
    grid-template-columns: 12rem minmax(0, 1fr);
    align-items: center;
    gap: var(--space-6);
  }
  .post-cover {
    display: block;
    width: 12rem;
    height: 12rem;
    overflow: hidden;
    border-radius: 4px;
  }
  .post-cover picture, .post-cover img { display: block; width: 12rem; height: 12rem; }
  .post-cover img { object-fit: cover; object-position: center; transition: transform 180ms ease; }
  .post-cover:hover img { transform: scale(1.025); }
  .post-card :global(.article-meta) { justify-content: flex-start; }
  h2 { max-width: 28ch; margin: var(--space-3) 0; font-size: clamp(1.5rem, 3vw, 1.6875rem); }
  h2 a { color: var(--color-ink-900); text-decoration: none; }
  h2 a:hover { color: var(--color-brand-700); text-decoration: underline; text-decoration-thickness: .06em; }
  .post-excerpt { max-width: 68ch; margin: 0; color: var(--color-ink-700); font-family: var(--font-editorial); font-size: 1.08rem; line-height: 1.65; }
  @media (max-width: 40rem) {
    .post-card--featured.post-card--has-cover { grid-template-columns: 7rem minmax(0, 1fr); gap: var(--space-4); align-items: start; }
    .post-cover, .post-cover picture, .post-cover img { width: 7rem; height: 7rem; }
    .post-card--featured h2 { margin: var(--space-2) 0; }
    .post-card--featured .post-excerpt { font-size: 1rem; line-height: 1.5; }
  }
  @media (prefers-reduced-motion: reduce) {
    .post-cover img { transition: none; }
  }
</style>
