---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const whatsappUrl = `https://wa.me/?text=${encodeURIComponent(`${title} — ${url}`)}`;
---

<section
  class="share-actions"
  aria-labelledby="share-title"
  data-share-actions
  data-title={title}
  data-url={url}
>
  <h2 id="share-title">Compartilhe esta reflexão</h2>
  <div class="share-actions__buttons">
    <button class="share-button" type="button" data-native-share aria-label="Compartilhar artigo" title="Compartilhar" hidden>
      <svg aria-hidden="true" viewBox="0 0 24 24">
        <circle cx="18" cy="5" r="2.5"></circle>
        <circle cx="6" cy="12" r="2.5"></circle>
        <circle cx="18" cy="19" r="2.5"></circle>
        <path d="m8.2 10.8 7.6-4.5M8.2 13.2l7.6 4.5"></path>
      </svg>
    </button>
    <a
      class="share-button"
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Compartilhar pelo WhatsApp"
      title="WhatsApp"
    >
      <svg aria-hidden="true" viewBox="0 0 24 24">
        <path d="M20.5 11.7a8.5 8.5 0 0 1-12.6 7.4L3 20.5l1.4-4.7a8.5 8.5 0 1 1 16.1-4.1Z"></path>
        <path d="M8.2 7.8c.2-.4.4-.4.7-.4h.4c.2 0 .4.1.5.4l.8 1.8c.1.3.1.5-.1.7l-.6.7c-.2.2-.1.4 0 .6.6 1.1 1.5 2 2.6 2.6.2.1.4.2.6 0l.8-1c.2-.2.4-.3.7-.2l1.8.9c.3.1.4.3.4.5 0 .3-.1 1.4-.9 2-.7.6-1.6.8-2.6.5-1-.3-2.3-.8-3.9-2.2-1.3-1.2-2.2-2.6-2.5-3.6-.3-1-.1-2.3.3-2.8.3-.3.6-.5 1-.5Z"></path>
      </svg>
    </a>
    <button class="share-button" type="button" data-copy-link aria-label="Copiar link do artigo" title="Copiar link" hidden>
      <svg aria-hidden="true" viewBox="0 0 24 24">
        <path d="m9.5 14.5 5-5"></path>
        <path d="m7.1 16.9-1.5 1.5a3.5 3.5 0 0 1-5-5l3.1-3.1a3.5 3.5 0 0 1 5 0"></path>
        <path d="m16.9 7.1 1.5-1.5a3.5 3.5 0 0 1 5 5l-3.1 3.1a3.5 3.5 0 0 1-5 0"></path>
      </svg>
    </button>
  </div>
  <p class="share-status" role="status" aria-live="polite"></p>
</section>

<script>
  const copyText = async (text: string) => {
    if (navigator.clipboard?.writeText) {
      await navigator.clipboard.writeText(text);
      return;
    }

    const input = document.createElement("textarea");
    input.value = text;
    input.setAttribute("readonly", "");
    input.style.position = "fixed";
    input.style.opacity = "0";
    document.body.append(input);
    input.select();
    const copied = document.execCommand("copy");
    input.remove();
    if (!copied) throw new Error("Copy command failed");
  };

  document.querySelectorAll<HTMLElement>("[data-share-actions]").forEach((container) => {
    const title = container.dataset.title ?? document.title;
    const url = container.dataset.url ?? window.location.href;
    const status = container.querySelector<HTMLElement>(".share-status");
    const shareButton = container.querySelector<HTMLButtonElement>("[data-native-share]");
    const copyButton = container.querySelector<HTMLButtonElement>("[data-copy-link]");

    if (copyButton) {
      copyButton.hidden = false;
      copyButton.addEventListener("click", async () => {
        try {
          await copyText(url);
          if (status) status.textContent = "Link copiado.";
        } catch {
          if (status) status.textContent = "Não foi possível copiar o link.";
        }
      });
    }

    if (shareButton && navigator.share) {
      shareButton.hidden = false;
      shareButton.addEventListener("click", async () => {
        try {
          await navigator.share({ title, url });
        } catch (error) {
          if (error instanceof DOMException && error.name === "AbortError") return;
          if (status) status.textContent = "Não foi possível compartilhar.";
        }
      });
    }
  });
</script>

<style>
  .share-actions {
    width: min(100% - 2rem, 720px);
    margin: 0 auto var(--space-9);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-line-300);
  }

  .share-actions h2 { margin: 0 0 var(--space-3); font-size: 1rem; }
  .share-actions__buttons { display: flex; flex-wrap: wrap; gap: var(--space-2) var(--space-4); }
  .share-button {
    display: inline-flex;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 50%;
    padding: 0;
    background: transparent;
    color: var(--color-ink-500);
    cursor: pointer;
    text-decoration: none;
  }
  .share-button svg {
    width: 23px;
    height: 23px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.7;
  }
  .share-button:hover {
    background: var(--color-paper-200);
    color: var(--color-brand-700);
  }
  .share-status {
    min-height: 1.5em;
    margin: var(--space-2) 0 0;
    color: var(--color-ink-500);
    font-size: .875rem;
  }

  @media print { .share-actions { display: none; } }
</style>
