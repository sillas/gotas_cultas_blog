---
// Reusable ad placement (PROJECT_SPEC.md section 7). Real AdSense/marketing
// script tags go here, gated behind the "consent-granted" event dispatched
// by CookieConsent.astro — never load third-party scripts before consent.
interface Props {
  slot: string;
}

const { slot } = Astro.props;
---

<div class="ad-slot" data-ad-slot={slot}>
  <!-- TODO: insert AdSense/marketing snippet, loaded on "consent-granted" -->
</div>

<style>
  .ad-slot {
    min-height: 90px;
    margin: 2rem 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed #ccc;
    color: #999;
    font-size: 0.8rem;
  }
</style>
