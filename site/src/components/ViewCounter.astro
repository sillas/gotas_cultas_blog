---
// Fires *after* the page has loaded from cache — keeps the HTML itself
// 100% cacheable at the CloudFront edge (PROJECT_SPEC.md section 4).
// A non-JS-executing scraper never triggers this, which is also why the
// view count stays reasonably honest without extra bot-filtering logic.
interface Props {
  slug: string;
}

const { slug } = Astro.props;
const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL ?? "/api";
---

<span data-view-counter data-slug={slug} data-api-base={apiBaseUrl}></span>

<script>
  const REQUIRED_VISIBLE_MS = 8_000;
  const el = document.querySelector("[data-view-counter]");

  if (el instanceof HTMLElement) {
    const slug = el.dataset.slug;
    const apiBase = el.dataset.apiBase;

    if (slug && apiBase) {
      const storageKey = `view-counted:${slug}`;
      let accumulatedVisibleMs = 0;
      let visibleSince: number | null = null;
      let timer: number | undefined;
      let finished = false;

      const wasAlreadyCounted = () => {
        try {
          return sessionStorage.getItem(storageKey) === "1";
        } catch {
          return false;
        }
      };

      const markAsCounted = () => {
        try {
          sessionStorage.setItem(storageKey, "1");
        } catch {
          // Storage can be unavailable in hardened/private browser contexts.
        }
      };

      const removeListeners = () => {
        document.removeEventListener("visibilitychange", handleVisibilityChange);
        window.removeEventListener("pagehide", stop);
      };

      const recordView = () => {
        if (finished || wasAlreadyCounted()) return;
        finished = true;
        window.clearTimeout(timer);
        removeListeners();
        markAsCounted();
        fetch(`${apiBase}/views/${encodeURIComponent(slug)}`, { method: "POST", keepalive: true }).catch(() => {
          // Best-effort: a failed view-count call must never affect the reading experience.
        });
      };

      const pause = () => {
        if (visibleSince !== null) {
          accumulatedVisibleMs += performance.now() - visibleSince;
          visibleSince = null;
        }
        window.clearTimeout(timer);
      };

      const resume = () => {
        if (finished || visibleSince !== null || document.visibilityState !== "visible") return;
        visibleSince = performance.now();
        const remainingMs = Math.max(0, REQUIRED_VISIBLE_MS - accumulatedVisibleMs);
        timer = window.setTimeout(recordView, remainingMs);
      };

      function handleVisibilityChange() {
        if (document.visibilityState === "visible") resume();
        else pause();
      }

      function stop() {
        pause();
        removeListeners();
      }

      const start = () => {
        if (wasAlreadyCounted()) return;
        document.addEventListener("visibilitychange", handleVisibilityChange);
        window.addEventListener("pagehide", stop, { once: true });
        resume();
      };

      if (document.readyState === "complete") start();
      else window.addEventListener("load", start, { once: true });
    }
  }
</script>
