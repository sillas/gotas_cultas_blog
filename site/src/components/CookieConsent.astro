---
// Consent gate (LGPD/GDPR — ADSENSE_READINESS_AND_RECOMMENDATIONS.md,
// "Alterações que podem ser feitas agora" #1 and #2). Analytics/AdSense are
// disabled today, so there is nothing optional to ask consent for — showing
// this banner would falsely claim third-party tracking is active and record
// an unnecessary "consent". The whole component is gated on ADSENSE_ENABLED
// and stays out of the page entirely until that flag is on.
//
// Before ever turning the flag on, this still needs the "Bloqueadores antes
// da ativação" item from that document: reject as prominent as accept, plus
// a way to review/revoke the choice later. Do not just flip the flag on this
// unchanged markup.
import { ADSENSE_ENABLED } from "../lib/flags";
---

{ADSENSE_ENABLED && (
  <>
    <section
      id="cookie-consent"
      class="cookie-consent"
      aria-label="Preferências de privacidade"
      aria-describedby="cookie-consent-description"
      hidden
    >
      <p id="cookie-consent-description">
        Usamos cookies para analytics e anúncios. Ao continuar, você concorda com a nossa
        <a href="/privacidade/" target="_blank" rel="noopener noreferrer">Política de Privacidade</a>.
      </p>
      <button id="cookie-consent-accept">Aceitar</button>
    </section>

    <script is:inline src="/scripts/cookie-consent.js" defer></script>
  </>
)}

<style>
  .cookie-consent[hidden] {
    display: none;
  }

  .cookie-consent {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: var(--color-brand-900);
    color: var(--color-on-brand);
    padding: var(--space-4) max(var(--space-4), calc((100vw - 1180px) / 2));
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    font-size: 0.9rem;
  }
  .cookie-consent a {
    color: var(--color-white);
  }
  .cookie-consent button {
    flex-shrink: 0;
    border: 0;
    border-radius: 6px;
    padding: var(--space-2) var(--space-5);
    background: var(--color-gold-500);
    color: var(--color-brand-900);
    font-weight: 700;
  }
  @media (max-width: 36rem) { .cookie-consent { align-items: stretch; flex-direction: column; } }
</style>
