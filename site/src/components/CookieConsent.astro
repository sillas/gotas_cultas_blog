---
// Minimal consent gate (LGPD/GDPR — PROJECT_SPEC.md section 7). Any script
// that loads AdSense/Analytics/marketing pixels must wait for the
// "consent-granted" event instead of running on page load.
---

<section
  id="cookie-consent"
  class="cookie-consent"
  aria-label="Preferências de privacidade"
  aria-describedby="cookie-consent-description"
  hidden
>
  <p id="cookie-consent-description">
    Usamos cookies para analytics e anúncios. Ao continuar, você concorda com a nossa
    <a href="/privacidade/">Política de Privacidade</a>.
  </p>
  <button id="cookie-consent-accept">Aceitar</button>
</section>

<script is:inline src="/scripts/cookie-consent.js" defer></script>

<style>
  .cookie-consent[hidden] {
    display: none;
  }

  .cookie-consent {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: var(--color-brand-900);
    color: var(--color-on-brand);
    padding: var(--space-4) max(var(--space-4), calc((100vw - 1180px) / 2));
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    font-size: 0.9rem;
  }
  .cookie-consent a {
    color: var(--color-white);
  }
  .cookie-consent button {
    flex-shrink: 0;
    border: 0;
    border-radius: 6px;
    padding: var(--space-2) var(--space-5);
    background: var(--color-gold-500);
    color: var(--color-brand-900);
    font-weight: 700;
  }
  @media (max-width: 36rem) { .cookie-consent { align-items: stretch; flex-direction: column; } }
</style>
