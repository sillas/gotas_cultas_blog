---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import AdSlot from "../components/AdSlot.astro";
import { getAllPosts, getCategories, getCategorySlug } from "../lib/content";

const posts = getAllPosts();
const featuredPost = posts[0];
const latestPosts = posts.slice(1, 5);
const categories = getCategories();
---

<BaseLayout title="Gotas Cultas — Teologia, filosofia e ciência" description="Reflexões breves e acessíveis sobre as grandes questões da teologia, da filosofia e da ciência." path="/">
  <section class="page-section slogan-section">
    <div class="golden-ocean" aria-hidden="true">
      <svg class="golden-ocean-art" viewBox="0 0 1440 360" preserveAspectRatio="none" style="position:absolute;left:0;bottom:0;width:100%;height:52%;overflow:hidden">
        <defs>
          <linearGradient id="golden-wave-back" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#e7aa2693" stop-opacity="0.30" />
            <stop offset="1" style="stop-color:var(--color-paper-50)" />
          </linearGradient>
          <linearGradient id="golden-wave-middle" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#c98f129a" stop-opacity="0.42" />
            <stop offset="1" style="stop-color:var(--color-paper-50)" />
          </linearGradient>
          <linearGradient id="golden-wave-front" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#e7aa268c" stop-opacity="0.56" />
            <stop offset="1" style="stop-color:var(--color-paper-50)" />
          </linearGradient>
        </defs>
        <g class="golden-wave-track golden-wave-track--back">
          <path fill="url(#golden-wave-back)" d="M0 105 C360 20 1080 190 1440 105 C1800 20 2520 190 2880 105 L2880 360 L0 360 Z" />
        </g>
        <g class="golden-wave-track golden-wave-track--middle">
          <path fill="url(#golden-wave-middle)" d="M0 135 C360 220 1080 50 1440 135 C1800 220 2520 50 2880 135 L2880 360 L0 360 Z" />
        </g>
        <g class="golden-wave-track golden-wave-track--front">
          <path fill="url(#golden-wave-front)" d="M0 165 C420 90 1020 240 1440 165 C1860 90 2460 240 2880 165 L2880 360 L0 360 Z" />
        </g>
      </svg>
    </div>
    <div class="container container--editorial">
      <p class="eyebrow">Teologia · Filosofia · Ciência</p>
      <h1>Pequenas reflexões sobre as grandes questões.</h1>
      <p class="lede">Textos breves para pensar com clareza, ler sem pressa e aprofundar questões sobre a fé, a razão e o mundo natural.</p>
    </div>
  </section>

  {featuredPost && (
    <section class="page-section featured-section">
      <div class="container container--editorial">
        <p class="eyebrow">Em destaque</p>
        <PostCard post={featuredPost} />
      </div>
    </section>
  )}

  <div class="container"><AdSlot slot="landing-top" /></div>

  <section class="page-section">
    <div class="container container--editorial">
      <h2 class="section-heading">Publicações recentes</h2>
      {posts.length === 0 && <p class="empty-state">As primeiras reflexões serão publicadas em breve.</p>}
      <div class="article-list recent-posts">{latestPosts.map((post) => <PostCard post={post} variant="recent" />)}</div>
      {posts.length > 0 && <p><a class="text-link" href="/blog/">Ver todas as publicações →</a></p>}
    </div>
  </section>

  <section class="page-section category-section">
    <div class="container container--editorial">
      <h2>Três caminhos do conhecimento</h2>
      <div class="category-links">
        <a href="/categoria/teologia/"><strong>Teologia</strong><span>Fé, Escrituras, tradição e vida cristã.</span></a>
        <a href="/categoria/filosofia/"><strong>Filosofia</strong><span>Realidade, conhecimento, ética e sentido.</span></a>
        <a href="/categoria/ciencia/"><strong>Ciência</strong><span>Natureza, universo, investigação e descoberta.</span></a>
      </div>
      {categories.filter((category) => !["teologia", "filosofia", "ciencia"].includes(getCategorySlug(category))).length > 0 && <p class="other-categories">Outros assuntos: {categories.filter((category) => !["teologia", "filosofia", "ciencia"].includes(getCategorySlug(category))).map((category) => <a href={`/categoria/${getCategorySlug(category)}/`}>{category}</a>)}</p>}
    </div>
  </section>
</BaseLayout>

<style>
  .slogan-section {
    position: relative;
    isolation: isolate;
    min-height: clamp(28rem, 68vh, 44rem);
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .slogan-section > .container { position: relative; z-index: 1; }
  .golden-ocean {
    position: absolute;
    z-index: 0;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .golden-wave-track { transform-box: fill-box; transform-origin: left center; will-change: transform; }
  .golden-wave-track--back { animation: golden-drift 15s linear infinite; }
  .golden-wave-track--middle { animation: golden-drift 10s linear infinite; }
  .golden-wave-track--front { animation: golden-drift 5s linear infinite; }
  @keyframes golden-drift { to { transform: translateX(-50%); } }
  .slogan-section + .featured-section { border-top: 0; }
  .featured-section { background: var(--color-paper-50); }
  .featured-section :global(.post-card) { border-bottom: 0; padding-bottom: 0; }
  .featured-section :global(.post-card h2) { font-size: clamp(1.875rem, 4vw, 2.25rem); }
  .recent-posts { display: grid; gap: var(--space-4); border-top: 0; }
  .category-links { display: grid; gap: var(--space-5); margin-top: var(--space-7); }
  .category-links a {
    padding: var(--space-5) 0 var(--space-5) var(--space-4);
    border-left: 5px solid var(--color-gold-500);
    color: var(--color-ink-900);
    text-decoration: none;
  }
  .category-links strong, .category-links span { display: block; }
  .category-links strong { font-family: var(--font-editorial); font-size: 1.5rem; }
  .category-links span { margin-top: var(--space-2); color: var(--color-ink-700); }
  .other-categories a { margin-left: var(--space-3); }
  @media (min-width: 48rem) { .category-links { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 40rem) {
    .slogan-section { min-height: clamp(28rem, 78svh, 38rem); }
    .golden-ocean-art { height: 45% !important; }
  }
  @media (prefers-reduced-motion: reduce) {
    .golden-wave-track { animation: none; }
  }
  @media print {
    .golden-ocean { display: none; }
  }
</style>
