---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import AdSlot from "../components/AdSlot.astro";
import { getAllPosts, getCategories } from "../lib/content";

const latestPosts = getAllPosts().slice(0, 5);
const categories = getCategories();
---

<BaseLayout title="Meu Blog" description="Últimos posts, categorias e destaques." path="/">
  <section>
    <h1>Meu Blog</h1>
    <p>Textos sobre [assunto do blog]. Publicação regular, sem enrolação.</p>
  </section>

  <AdSlot slot="landing-top" />

  <section>
    <h2>Últimos posts</h2>
    {latestPosts.length === 0 && <p>Nenhum post publicado ainda.</p>}
    {latestPosts.map((post) => <PostCard post={post} />)}
    <p><a href="/blog/">Ver todos os posts →</a></p>
  </section>

  {categories.length > 0 && (
    <section>
      <h2>Categorias</h2>
      <ul>
        {categories.map((category) => (
          <li><a href={`/categoria/${category}/`}>{category}</a></li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>
