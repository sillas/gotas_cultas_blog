---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getCategories, getCategorySlug, getPostsByCategory } from "../../lib/content";

export async function getStaticPaths() {
  const categories = new Set([...getCategories().map(getCategorySlug), "teologia", "filosofia"]);
  return Array.from(categories).map((category) => ({ params: { category } }));
}

const { category } = Astro.params;
const posts = getPostsByCategory(category as string);
const storedCategory = posts[0]?.category;
const label = storedCategory ?? (category ? category.charAt(0).toUpperCase() + category.slice(1).replaceAll("-", " ") : "Categoria");
const descriptions: Record<string, string> = {
  teologia: "Reflexões sobre fé, Escrituras, tradição e a experiência cristã.",
  filosofia: "Questões sobre realidade, conhecimento, ética e o sentido da vida.",
};
---

<BaseLayout
  title={`${label} — Gotas Cultas`}
  description={`Posts na categoria ${category}.`}
  path={`/categoria/${category}/`}
>
  <section class="page-section"><div class="container container--editorial">
    <p class="eyebrow">Categoria</p><h1>{label}</h1>
    <p class="lede">{descriptions[category?.toLowerCase() ?? ""] ?? `Textos publicados em ${label}.`}</p>
    <div class="article-list">{posts.map((post) => <PostCard post={post} />)}</div>
    {posts.length === 0 && <p class="empty-state">Ainda não há publicações nesta categoria.</p>}
  </div></section>
</BaseLayout>
