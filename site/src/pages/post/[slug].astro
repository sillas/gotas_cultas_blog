---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdSlot from "../../components/AdSlot.astro";
import ViewCounter from "../../components/ViewCounter.astro";
import ArticleMeta from "../../components/ArticleMeta.astro";
import { getAllPosts, getPostBySlug } from "../../lib/content";
import { renderMarkdown } from "../../lib/markdown";
import { canonicalUrl } from "../../lib/seo";

export async function getStaticPaths() {
  return getAllPosts().map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = getPostBySlug(slug as string);

if (!post) {
  return Astro.redirect("/404/");
}

const contentHtml = renderMarkdown(post.contentMarkdown);
const readingMinutes = Math.max(1, Math.ceil(post.contentMarkdown.trim().split(/\s+/).length / 220));
const authorName = post.author.name;
const responsiveCover = post.coverImage?.status === "ready" ? post.coverImage : null;
const avifVariants = responsiveCover?.variants.filter((variant) => variant.format === "avif").sort((a, b) => a.width - b.width) ?? [];
const webpVariants = responsiveCover?.variants.filter((variant) => variant.format === "webp").sort((a, b) => a.width - b.width) ?? [];
const fallbackVariant = webpVariants.at(-1);
const coverUrl = fallbackVariant?.url ?? responsiveCover?.fallbackUrl;
const coverWidth = fallbackVariant?.width ?? responsiveCover?.width;
const coverHeight = fallbackVariant?.height ?? responsiveCover?.height;
const imageSrcset = (variants: typeof webpVariants) => variants.map((variant) => `${variant.url} ${variant.width}w`).join(", ");
const absoluteCoverUrl = coverUrl ? canonicalUrl(Astro.site ?? "https://example.com", coverUrl) : undefined;
const formattedPublishDate = post.publishAt
  ? new Date(post.publishAt).toLocaleDateString("pt-BR", { day: "2-digit", month: "long", year: "numeric" })
  : "";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  description: post.description,
  datePublished: post.publishAt,
  dateModified: post.updatedAt,
  image: absoluteCoverUrl ? [absoluteCoverUrl] : undefined,
  author: { "@type": "Person", name: authorName },
};
---

<BaseLayout
  title={post.title}
  description={post.description}
  path={`/post/${post.slug}/`}
  image={coverUrl ?? undefined}
  type="article"
  jsonLd={jsonLd}
>
  <article>
    <header class="article-header container container--editorial">
      <p class="article-category">{post.category}</p>
      <h1>{post.title}</h1>
      <p class="lede">{post.description}</p>
      <div class="article-meta--screen">
        <ArticleMeta category={post.category} publishAt={post.publishAt} readingMinutes={readingMinutes} />
      </div>
      <p class="article-print-meta">
        <span>Por {authorName}</span>
        {formattedPublishDate && <span>Publicado em <time datetime={post.publishAt ?? undefined}>{formattedPublishDate}</time></span>}
      </p>
      <div class="article-screen-tools">
        <ViewCounter slug={post.slug} />
        <button class="print-button" type="button" data-print-button>
          <svg aria-hidden="true" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 9V3h12v6M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
            <path d="M6 14h12v7H6z" />
          </svg>
          Imprimir artigo
        </button>
      </div>
    </header>

    {coverUrl && (
      <figure class="article-cover">
        <picture>
          {avifVariants.length > 0 && <source type="image/avif" srcset={imageSrcset(avifVariants)} sizes="(max-width: 880px) 100vw, 880px" />}
          {webpVariants.length > 0 && <source type="image/webp" srcset={imageSrcset(webpVariants)} sizes="(max-width: 880px) 100vw, 880px" />}
          <img
            src={coverUrl}
            alt={post.title}
            width={coverWidth ?? undefined}
            height={coverHeight ?? undefined}
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </picture>
      </figure>
    )}

    <div class="article-body container container--reading" set:html={contentHtml} />
  </article>

  <div class="container container--reading"><AdSlot slot="post-bottom" /></div>
</BaseLayout>

<script is:inline src="/scripts/print.js" defer></script>
